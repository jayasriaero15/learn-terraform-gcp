resource "google_service_account" "storage_viewer_sa" {
  account_id   = "storage-viewer-sa"
  display_name = "Access google cloud storage"
}

resource "google_storage_bucket_iam_member" "storage_viewer_role" {
  role   = "roles/storage.objectViewer"
  bucket = google_storage_bucket.test_bucket.name
  member = "serviceAccount:${google_service_account.storage_viewer_sa.email}"
}


resource "google_project_iam_member" "sriram_editor_role" {
  project = var.project_id
  role    = "roles/editor"
  member  = "user:srirammadhiyazhagan@gmail.com"
}

resource "google_compute_instance_iam_member" "sriram_compute_role" {
  project  = var.project_id
  role     = "roles/compute.osAdminLogin"
  member   = "user:srirammadhiyazhagan@gmail.com"
  instance_name = google_compute_instance.my_test_intance.name
  zone     = var.zone
}

resource "google_compute_instance_iam_member" "sriram_compute_instanceAdmin_role" {
  project  = var.project_id
  role     = "roles/compute.instanceAdmin.v1"
  member   = "user:srirammadhiyazhagan@gmail.com"
  instance_name = google_compute_instance.my_test_intance.name
  zone     = var.zone
}

resource "google_project_iam_member" "sriram_iap_tunnel" {
  project = var.project_id
  role    = "roles/iap.tunnelResourceAccessor"
  member  = "user:srirammadhiyazhagan@gmail.com"
}
